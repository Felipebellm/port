name: Deploy to __ENVIRONMENT__

on:
  push:
    branches: [__BRANCH__]

concurrency:
  group: __ENVIRONMENT__-deploy
  cancel-in-progress: true

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Deploy on VPS via SSH
        uses: appleboy/ssh-action@v1.0.3
        with:
          host: ${{ secrets.VPS_HOST }}
          username: ${{ secrets.VPS_USER }}
          key: ${{ secrets.VPS_SSH_KEY }}
          port: ${{ secrets.VPS_PORT || 22 }}
          script: bash __DEPLOY_SCRIPT_PATH__

      - name: Health check
        run: |
          echo "==> Waiting for deploy to settle..."
          sleep 5
          HTTP_CODE=$(curl -o /dev/null -s -w "%{http_code}" \
            https://__DOMAIN__/ --max-time 15)
          echo "HTTP response code: ${HTTP_CODE}"
          if [[ "${HTTP_CODE}" != "200" ]]; then
            echo "ERROR: Health check failed with HTTP ${HTTP_CODE}" >&2
            exit 1
          fi
          echo "==> Health check passed."
