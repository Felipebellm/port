# __PROJECT_NAME__ - __ENVIRONMENT__
# Reverse proxy to a backend container. If the project also has a static
# frontend, that's normally served directly via nginx `root` (see
# nginx-static-site.conf.template) rather than routed through this proxy -
# only the backend needs a container/port here.
server {
    listen 80;
    server_name __DOMAIN__;

    # If this VPS has shared snippets from other projects (security headers,
    # ACME-challenge handling), reuse them here instead of duplicating:
    # include snippets/acme-challenge.conf;
    # include snippets/security-headers.conf;

    location / {
        proxy_pass http://127.0.0.1:__HOST_PORT__;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}

# After this is in place, run:
#   sudo certbot --nginx -d __DOMAIN__
# to provision HTTPS. Certbot will rewrite this file to add the SSL block automatically.
