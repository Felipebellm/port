#!/usr/bin/env bash
set -euo pipefail

APP_DIR="__APP_DIR__"
cd "$APP_DIR"

echo "==> [1/3] Syncing to latest __BRANCH__ (discarding any local drift)..."
# Force the working tree to match remote exactly - a deploy box should never
# carry local edits forward.
git fetch origin __BRANCH__
git reset --hard origin/__BRANCH__
git clean -fd

echo "==> [2/3] Building frontend..."
cd __FRONTEND_DIR__
npm ci --prefer-offline
npm run build

if [[ ! -f dist/index.html ]]; then
  echo "ERROR: build failed - dist/index.html not found" >&2
  exit 1
fi

echo "==> [3/3] Done. nginx serves dist/ directly, no reload needed for content-only changes."
