# __PROJECT_NAME__ - __ENVIRONMENT__
# Static build, served directly by nginx - no backend, no container.

server {
    listen 80;
    server_name __DOMAIN__;

    root __ROOT_DIR__;
    index index.html;

    # If this VPS has shared snippets from other projects (security headers,
    # ACME-challenge handling), reuse them here instead of duplicating:
    # include snippets/acme-challenge.conf;
    # include snippets/security-headers.conf;

    # Cache hashed static assets aggressively (Vite/webpack content-hash filenames)
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|otf|webp)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    location ~ /\.(?!well-known).* { deny all; }

    # Single-page app - all routes fall back to index.html
    location / {
        try_files $uri $uri/ /index.html;
    }
}

# After this is in place, run:
#   sudo certbot --nginx -d __DOMAIN__
# to provision HTTPS. Certbot will rewrite this file to add the SSL block
# and the HTTP->HTTPS redirect automatically.
